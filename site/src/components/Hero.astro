---
import { SITE } from "../data/site";

type Props = {
	latestVersion?: string;
	latestUrl?: string;
};

const { latestVersion, latestUrl } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const downloadHref = latestUrl ?? `${baseUrl}/releases`;
const downloadLabel = latestVersion
	? `Baixar v${latestVersion}`
	: "Ver downloads";
---

<section class="relative overflow-hidden">
	<div class="absolute inset-0 bg-radial-glow pointer-events-none" aria-hidden="true"></div>
	<div class="absolute inset-0 bg-grid opacity-40 pointer-events-none [mask-image:radial-gradient(ellipse_at_top,black_30%,transparent_70%)]" aria-hidden="true"></div>

	<div class="relative max-w-6xl mx-auto px-6 pt-20 pb-16 md:pt-28 md:pb-24">
		<div class="max-w-3xl">
			<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--color-border-strong)] bg-[var(--color-bg-elevated)]/60 text-xs text-[var(--color-fg-muted)] mb-6">
				<span class="size-1.5 rounded-full bg-[var(--color-accent)] animate-pulse"></span>
				<span>{SITE.requirements}</span>
			</div>

			<h1 class="text-4xl md:text-6xl lg:text-7xl font-semibold tracking-tight leading-[1.05] mb-6">
				O command palette<br />
				<span class="text-[var(--color-accent)]">nativo do macOS</span><br />
				para quem vive no teclado.
			</h1>

			<p class="text-lg md:text-xl text-[var(--color-fg-muted)] leading-relaxed max-w-2xl mb-10">
				{SITE.description}
			</p>

			<div class="flex flex-wrap items-center gap-3">
				<a
					href={downloadHref}
					class="group inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-black font-semibold transition-all shadow-lg shadow-[var(--color-accent-soft)] hover:shadow-[var(--color-accent-ring)] hover:-translate-y-0.5"
				>
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4">
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
						<polyline points="7 10 12 15 17 10" />
						<line x1="12" y1="15" x2="12" y2="3" />
					</svg>
					<span>{downloadLabel}</span>
				</a>

				<a
					href={SITE.githubUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 px-5 py-3 rounded-lg border border-[var(--color-border-strong)] bg-[var(--color-bg-elevated)]/60 hover:bg-[var(--color-bg-elevated)] text-[var(--color-fg)] font-medium transition-colors"
				>
					<svg viewBox="0 0 24 24" fill="currentColor" class="size-4">
						<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
					</svg>
					<span>Ver no GitHub</span>
				</a>
			</div>

			<div class="mt-8 flex items-center gap-3 text-sm text-[var(--color-fg-subtle)]">
				<span>Atalho global</span>
				<kbd class="inline-flex items-center gap-1 px-2 py-1 rounded-md border border-[var(--color-border)] bg-[var(--color-bg-elevated)]/60 font-mono text-xs text-[var(--color-fg)]">
					{SITE.hotkey}
				</kbd>
			</div>
		</div>
	</div>
</section>
