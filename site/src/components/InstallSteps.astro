---
import { SITE } from "../data/site";

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

const steps = [
	{
		n: 1,
		title: "Baixe o último release",
		body: "Arquivo .zip único contendo o app, assinado pra Apple Silicon (arm64).",
		cta: { label: "Ver downloads", href: `${baseUrl}/releases` },
	},
	{
		n: 2,
		title: "Mova para /Applications",
		body: "Descompacte e arraste Ptolomeu.app para a pasta Aplicativos. Na primeira execução, autorize em Configurações → Privacidade & Segurança.",
	},
	{
		n: 3,
		title: "Aperte ⌘+Shift+Space",
		body: "O ícone aparece na barra de menu (sem ícone no Dock). O atalho global abre a paleta sobre qualquer app.",
	},
] as const;
---

<section id="instalar" class="relative py-20 md:py-28 border-t border-[var(--color-border)]/60">
	<div class="max-w-6xl mx-auto px-6">
		<div class="max-w-2xl mb-12">
			<p class="text-sm font-mono text-[var(--color-accent)] uppercase tracking-wider mb-3">
				Como instalar
			</p>
			<h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4">
				Três passos do download ao primeiro atalho
			</h2>
			<p class="text-lg text-[var(--color-fg-muted)] leading-relaxed">
				{SITE.requirements}.
			</p>
		</div>

		<ol class="grid grid-cols-1 md:grid-cols-3 gap-4">
			{
				steps.map((step) => (
					<li class="relative p-6 rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-bg-card)]">
						<div class="flex items-center justify-center size-9 rounded-full border border-[var(--color-accent)]/40 bg-[var(--color-accent-soft)] text-[var(--color-accent)] font-mono text-sm font-semibold mb-4">
							{step.n}
						</div>
						<h3 class="text-lg font-semibold text-[var(--color-fg)] mb-2">
							{step.title}
						</h3>
						<p class="text-sm text-[var(--color-fg-muted)] leading-relaxed mb-4">
							{step.body}
						</p>
						{"cta" in step && step.cta && (
							<a
								href={step.cta.href}
								class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
							>
								{step.cta.label}
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5">
									<line x1="5" y1="12" x2="19" y2="12" />
									<polyline points="12 5 19 12 12 19" />
								</svg>
							</a>
						)}
					</li>
				))
			}
		</ol>
	</div>
</section>
