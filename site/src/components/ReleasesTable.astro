---
type Asset = { name: string; size: number; url: string };
type Release = {
	version: string;
	tagName: string;
	publishedAt: string | null;
	htmlUrl: string;
	mirrorUrl: string | null;
	notesUrl: string;
	assets: Asset[];
	prerelease: boolean;
};

type Props = { releases: Release[]; latestVersion: string | null };
const { releases, latestVersion } = Astro.props;

const fmtDate = new Intl.DateTimeFormat("pt-BR", {
	day: "2-digit",
	month: "short",
	year: "numeric",
});

function fmtSize(bytes: number): string {
	if (bytes < 1024) return `${bytes} B`;
	if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(0)} KB`;
	return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}
---

{
	releases.length === 0 ? (
		<div class="rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-bg-card)] p-8 text-center">
			<p class="text-[var(--color-fg-muted)]">
				Nenhum release listado ainda. Confira em{" "}
				<a
					href="https://github.com/guichafy/ptolomeu/releases"
					class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]"
				>
					GitHub Releases
				</a>
				.
			</p>
		</div>
	) : (
		<div class="rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-bg-card)] overflow-hidden">
			<table class="w-full text-sm">
				<thead>
					<tr class="border-b border-[var(--color-border)]/60 text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
						<th class="text-left font-medium px-5 py-3">Versão</th>
						<th class="text-left font-medium px-5 py-3 hidden md:table-cell">Publicado</th>
						<th class="text-left font-medium px-5 py-3">Download</th>
						<th class="text-right font-medium px-5 py-3">Notas</th>
					</tr>
				</thead>
				<tbody>
					{releases.map((rel) => {
						const isLatest = latestVersion === rel.version;
						const primary = rel.assets.find((a) => a.name.endsWith(".zip")) ?? rel.assets[0];
						return (
							<tr class="border-b border-[var(--color-border)]/40 last:border-0 hover:bg-[var(--color-bg-elevated)]/40 transition-colors">
								<td class="px-5 py-4 align-top">
									<div class="flex items-center gap-2">
										<code class="font-mono font-medium text-[var(--color-fg)]">
											v{rel.version}
										</code>
										{isLatest && (
											<span class="text-[10px] uppercase tracking-wider font-semibold px-1.5 py-0.5 rounded bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
												latest
											</span>
										)}
										{rel.prerelease && (
											<span class="text-[10px] uppercase tracking-wider font-semibold px-1.5 py-0.5 rounded bg-white/10 text-[var(--color-fg-muted)]">
												pre-release
											</span>
										)}
									</div>
								</td>
								<td class="px-5 py-4 align-top text-[var(--color-fg-muted)] hidden md:table-cell">
									{rel.publishedAt ? fmtDate.format(new Date(rel.publishedAt)) : "—"}
								</td>
								<td class="px-5 py-4 align-top">
									{primary ? (
										<a
											href={rel.mirrorUrl ?? primary.url}
											class="inline-flex items-center gap-2 text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] font-medium"
										>
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5">
												<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
												<polyline points="7 10 12 15 17 10" />
												<line x1="12" y1="15" x2="12" y2="3" />
											</svg>
											<span class="font-mono text-xs">{primary.name}</span>
											<span class="text-[var(--color-fg-subtle)] text-xs">({fmtSize(primary.size)})</span>
										</a>
									) : (
										<span class="text-[var(--color-fg-subtle)]">—</span>
									)}
								</td>
								<td class="px-5 py-4 align-top text-right">
									<a
										href={rel.htmlUrl}
										target="_blank"
										rel="noopener noreferrer"
										class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] text-sm"
									>
										ver →
									</a>
								</td>
							</tr>
						);
					})}
				</tbody>
			</table>
		</div>
	)
}
