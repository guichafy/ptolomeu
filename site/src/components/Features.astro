---
import { PLUGINS } from "../data/site";
import PluginCard from "./PluginCard.astro";
---

<section id="features" class="relative py-20 md:py-28">
	<div class="max-w-6xl mx-auto px-6">
		<div class="max-w-2xl mb-12">
			<p class="text-sm font-mono text-[var(--color-accent)] uppercase tracking-wider mb-3">
				Plugins
			</p>
			<h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4">
				Cinco superfícies, um único atalho
			</h2>
			<p class="text-lg text-[var(--color-fg-muted)] leading-relaxed">
				A paleta vem com plugins prontos pra usar. Tab alterna entre eles
				instantaneamente — sem perder o contexto da query.
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
			{PLUGINS.map((plugin) => <PluginCard plugin={plugin} />)}
		</div>
	</div>
</section>
