---
import { SCREENSHOTS } from "../data/site";

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section id="showcase" class="relative py-20 md:py-28 border-t border-[var(--color-border)]/60">
	<div class="max-w-6xl mx-auto px-6">
		<div class="max-w-2xl mb-12">
			<p class="text-sm font-mono text-[var(--color-accent)] uppercase tracking-wider mb-3">
				Em uso
			</p>
			<h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4">
				Tudo na mesma janela, no mesmo atalho
			</h2>
			<p class="text-lg text-[var(--color-fg-muted)] leading-relaxed">
				Capturas reais geradas pela pipeline E2E. A paleta aparece sobre
				qualquer aplicativo, sem roubar o foco do que você estava fazendo.
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			{
				SCREENSHOTS.map((shot) => (
					<figure class="group relative rounded-[var(--radius-card)] overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-card)] hover:border-[var(--color-border-strong)] transition-colors">
						<div class="aspect-[4/3] overflow-hidden bg-black">
							<img
								src={`${baseUrl}/screenshots/${shot.src}`}
								alt={shot.alt}
								loading="lazy"
								decoding="async"
								class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
							/>
						</div>
						<figcaption class="p-5 border-t border-[var(--color-border)]/60">
							<div class="flex items-start justify-between gap-3">
								<p class="text-sm text-[var(--color-fg-muted)] leading-relaxed flex-1">
									{shot.caption}
								</p>
								<span class="shrink-0 text-xs font-mono uppercase tracking-wider text-[var(--color-accent)] px-2 py-0.5 rounded-md bg-[var(--color-accent-soft)]">
									{shot.plugin}
								</span>
							</div>
						</figcaption>
					</figure>
				))
			}
		</div>
	</div>
</section>
