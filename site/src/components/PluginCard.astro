---
import type { Plugin } from "../data/site";
import PluginIcon from "./PluginIcon.astro";

type Props = { plugin: Plugin };
const { plugin } = Astro.props;
---

<article class="group relative p-6 rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-bg-card)] hover:bg-[var(--color-bg-elevated)] hover:border-[var(--color-border-strong)] transition-all duration-200">
	<div class="absolute inset-0 rounded-[var(--radius-card)] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="background: radial-gradient(400px circle at var(--mx, 50%) var(--my, 50%), var(--color-accent-soft), transparent 60%);"></div>

	<div class="relative">
		<div class="flex items-start justify-between mb-4">
			<div class="flex items-center justify-center size-10 rounded-lg bg-[var(--color-bg-elevated)] border border-[var(--color-border)] text-[var(--color-fg-muted)] group-hover:text-[var(--color-accent)] group-hover:border-[var(--color-accent)]/30 transition-colors">
				<PluginIcon icon={plugin.icon} class="size-5" />
			</div>
			<span class="text-xs font-mono text-[var(--color-fg-subtle)] uppercase tracking-wider">
				{plugin.id}
			</span>
		</div>

		<h3 class="text-lg font-semibold text-[var(--color-fg)] mb-1">
			{plugin.name}
		</h3>
		<p class="text-sm text-[var(--color-fg-muted)] mb-3">{plugin.tagline}</p>
		<p class="text-sm text-[var(--color-fg-subtle)] leading-relaxed mb-4">
			{plugin.description}
		</p>

		<div class="pt-4 border-t border-[var(--color-border)]/60">
			<div class="flex items-center gap-2 text-xs">
				<span class="text-[var(--color-fg-subtle)]">Exemplo</span>
				<code class="font-mono text-[var(--color-fg-muted)] truncate">
					{plugin.example}
				</code>
			</div>
		</div>
	</div>
</article>
