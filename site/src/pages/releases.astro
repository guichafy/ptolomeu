---
import BaseLayout from "../layouts/BaseLayout.astro";
import ReleasesTable from "../components/ReleasesTable.astro";
import { fetchReleases } from "../lib/releases";
import { SITE } from "../data/site";

const { releases, latestVersion, source } = await fetchReleases(20);
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
	title="Downloads"
	description="Histórico de releases do Ptolomeu, incluindo o mais recente para macOS Apple Silicon."
	pathname="/releases"
>
	<section class="relative pt-16 pb-8 md:pt-24 md:pb-12">
		<div class="absolute inset-0 bg-radial-glow pointer-events-none" aria-hidden="true"></div>
		<div class="relative max-w-5xl mx-auto px-6">
			<p class="text-sm font-mono text-[var(--color-accent)] uppercase tracking-wider mb-3">
				Downloads
			</p>
			<h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4">
				Releases
			</h1>
			<p class="text-lg text-[var(--color-fg-muted)] max-w-2xl">
				Todas as versões publicadas do Ptolomeu para macOS Apple Silicon. Os
				zips ficam mirror-hospedados no GitHub Pages para downloads diretos
				sem login.
			</p>

			<div class="mt-6 flex flex-wrap items-center gap-3 text-sm">
				<a
					href={`${baseUrl}/latest.json`}
					class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-bg-elevated)]/60 hover:bg-[var(--color-bg-elevated)] text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] font-mono text-xs transition-colors"
				>
					latest.json
				</a>
				<a
					href={SITE.releasesUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-bg-elevated)]/60 hover:bg-[var(--color-bg-elevated)] text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] text-xs transition-colors"
				>
					Releases no GitHub
				</a>
				{
					source === "empty" && (
						<span class="text-xs text-[var(--color-fg-subtle)]">
							Build sem GITHUB_TOKEN — lista vazia em dev local é esperado.
						</span>
					)
				}
			</div>
		</div>
	</section>

	<section class="pb-20">
		<div class="max-w-5xl mx-auto px-6">
			<ReleasesTable releases={releases} latestVersion={latestVersion} />
		</div>
	</section>
</BaseLayout>
