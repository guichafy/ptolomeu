{
	"name": "electrobun-react-tailwind-vite",
	"version": "1.0.0",
	"description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
	"scripts": {
		"build:native": "clang -dynamiclib -framework AppKit -fobjc-arc -o src/bun/native/liboverlay.dylib src/bun/native/overlay.m -arch arm64",
		"start": "bun run build:native && vite build && electrobun dev",
		"dev": "bun run build:native && vite build && electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "bun run build:native && vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-slot": "^1.2.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"electrobun": "1.16.0",
		"lucide-react": "^1.7.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"shadcn": "^4.1.2",
		"tailwindcss": "^3.4.16",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
